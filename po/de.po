msgstr "Füge deine eigenen Startoptionen hinzu."

#: src/widgets/games/launch-options-editor.vala:662
msgid "Advanced options"
msgstr "Erweiterte Optionen"

#: src/widgets/games/launch-options-editor.vala:663
