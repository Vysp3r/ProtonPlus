#: src/models/runners/steamtinkerlaunch.vala:6
msgid ""
"Steam tool for easy, graphical configuration of your other compatibility "
"tools for both Windows games and native Linux games."
msgstr ""
"Ferramenta do Steam para configuração fácil e gráfica de suas outras "
"ferramentas de compatibilidade para jogos de Windows e nativos Linux."

#: src/translatables.vala:4
msgid "Compatibility tools by Valve for running Windows software on Linux."
msgstr ""
"Ferramentas de compatibilidade da Valve para executar programas do Windows "
"no Linux."

#: src/translatables.vala:5
msgid ""
"Steam compatibility tool for running Windows games with improvements over "
"Valve's default Proton."
msgstr ""
"Ferramenta de compatibilidade do Steam para executar jogos do Windows com "
"melhorias sobre o Proton padrão da Valve."

#: src/translatables.vala:6
msgid ""
"Steam compatibility tool from the CachyOS Linux distribution for running "
"Windows games with improvements over Valve's default Proton."
msgstr ""
"Ferramenta de compatibilidade do Steam da distribuição Linux CachyOS para "
"executar jogos do Windows com melhorias sobre o Proton padrão da Valve."

#: src/translatables.vala:7
msgid "Dawn Winery's custom Proton fork with fixes for various games :xdd:"
msgstr ""
"Derivação do Proton por Dawn Winery com correções para vários jogos :xdd:"

#: src/translatables.vala:8
msgid ""
"Steam compatibility tool for running Windows games with improvements over "
"Valve's default Proton. By Etaash Mathamsetty adding FSR4 support and wine "
"wayland tweaks."
msgstr ""
"Ferramenta de compatibilidade do Steam para executar jogos de Windows com "
"melhorias sobre o Proton padrão da Valve. Por Etaash Mathamsetty adicionando "
"suporte a FSR4 e ajustes para Wine em Wayland."

#: src/translatables.vala:9
msgid "Custom Proton build for running Windows games, based on Wine-tkg."
msgstr ""
"Versão Proton customizada para executar jogos de Windows, baseada em Wine-"
"tkg."

#: src/translatables.vala:10
msgid ""
"Steam compatibility tool based on Proton-GE with additional patches to "
"improve RTSP codecs for VRChat."
msgstr ""
"Ferramenta de compatibilidade do Steam, baseada no Proton-GE com "
"modificações adicionais para melhorar (de)codificadores RTSP para VRChat."

#: src/translatables.vala:11
msgid ""
"Luxtorpeda provides Linux-native game engines for certain Windows-only games."
msgstr ""
"O Luxtorpeda fornece motores de jogo nativos para Linux para jogos "
"específicos exclusivos de Windows."

#: src/translatables.vala:12
msgid ""
"Steam compatibility tool for running adventure games using ScummVM for Linux."
msgstr ""
"Ferramenta de compatibilidade do Steam para executar jogos de aventura "
"usando ScummVM para Linux."

#: src/translatables.vala:13
msgid "Steam compatibility tool for running DOS games using DOSBox for Linux."
msgstr ""
"Ferramenta de compatibilidade do Steam para executar jogos de DOS usando "
"DOSBox para Linux."

#: src/translatables.vala:14
msgid "Compatibility tools for running Windows software on Linux."
msgstr ""
"Ferramentas de compatibilidade para executar programas do Windows no Linux."

#: src/translatables.vala:15
msgid "Wine build compiled from the official WineHQ sources."
msgstr "Versão do Wine compilada a partir das fontes oficiais do WineHQ."

#: src/translatables.vala:16
msgid "Wine build with the Staging patchset."
msgstr "Versão do Wine com o conjunto de modificações Staging aplicados."

#: src/translatables.vala:17
msgid "Wine build with the Staging patchset and many other useful patches."
msgstr ""
"Versão do Wine com o conjunto de modificações Staging aplicados e com muitas "
"outras modificações adicionais úteis."

#: src/translatables.vala:18
msgid "Wine build modified by Valve and other contributors."
msgstr "Versão do Wine modificada pela Valve e outros contribuidores."

#: src/translatables.vala:19
msgid "Vulkan-based implementation of Direct3D 8, 9, 10 and 11 for Linux/Wine."
msgstr ""
"Implementação baseada em Vulkan do Direct3D 8, 9, 10 e 11 para Linux/Wine."

#: src/translatables.vala:20
msgid "DXVK builds that work with pre-Vulkan 1.3 versions."
msgstr "Versões do DXVK que funcionam com versões pré-Vulkan 1.3."

#: src/translatables.vala:21
msgid "DXVK Async builds that work with pre-Vulkan 1.3 versions."
msgstr "Versões do DXVK Async que funcionam com versões pré-Vulkan 1.3."

#: src/translatables.vala:22
msgid "DXVK builds with gplasync patch by Ph42oN."
msgstr "Versões do DXVK com a modificação gplasync por Ph42oN."

#: src/translatables.vala:23
msgid ""
"Variant of Wine's VKD3D which aims to implement the full Direct3D 12 API on "
"top of Vulkan."
msgstr ""
"Variante do VKD3D do Wine que visa implementar a API completa do Direct3D 12 "
"sobre o Vulkan."

