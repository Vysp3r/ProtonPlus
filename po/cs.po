#: src/launchers/bottles.vala:6 src/launchers/steam.vala:6
msgid "Runners"
msgstr "Spouštěče"

#: src/launchers/bottles.vala:7 src/launchers/hgl.vala:11
#: src/launchers/lutris.vala:7
msgid "Compatibility tools for running Windows software on Linux."
msgstr "Nástroje kompatibility pro spouštění softwaru pro Windows na Linuxu."

#: src/launchers/bottles.vala:11 src/launchers/hgl.vala:15
#: src/launchers/lutris.vala:11
msgid "Vulkan-based implementation of Direct3D 9, 10 and 11 for Linux/Wine."
msgstr "Implementace Direct3D 9, 10 a 11 pro Linux/Wine založená na Vulkanu."

#: src/launchers/bottles.vala:50 src/launchers/hgl.vala:86
msgid "Contains improvements over Valve's default Proton."
msgstr "Obsahuje vylepšení oproti výchozímu Protonu od Valve."

#: src/launchers/bottles.vala:54 src/launchers/hgl.vala:62
#: src/launchers/lutris.vala:54
msgid ""
"Based on Valve Proton Experimental's bleeding-edge Wine, built for Lutris."
msgstr ""
"Založeno na nejnovějším Wine z Proton Experimental od Valve, sestaveno pro "
"Lutris."

#: src/launchers/bottles.vala:58 src/launchers/lutris.vala:58
msgid ""
"Improved by Lutris to offer better compatibility or performance in certain "
"games."
msgstr ""
"Vylepšeno Lutrisem pro lepší kompatibilitu nebo výkon v určitých hrách."

#: src/launchers/hgl.vala:7
msgid "Compatibility tools by Valve for running Windows software on Linux."
msgstr ""
"Nástroje kompatibility od Valve pro spouštění softwaru pro Windows na Linuxu."

#: src/launchers/hgl.vala:19 src/launchers/lutris.vala:15
msgid ""
"Variant of Wine's VKD3D which aims to implement the full Direct3D 12 API on "
"top of Vulkan."
msgstr ""
"Varianta VKD3D z Wine, jejímž cílem je implementovat plné rozhraní API "
"Direct3D 12 na Vulkanu."

#: src/launchers/hgl.vala:66 src/launchers/lutris.vala:61
msgid "Wine build compiled from the official WineHQ sources."
msgstr "Sestavení Wine zkompilované z oficiálních zdrojů WineHQ."

#: src/launchers/hgl.vala:69 src/launchers/lutris.vala:64
msgid "Wine build with the Staging patchset."
msgstr "Wine sestavené se sadou patchů Staging."

#: src/launchers/hgl.vala:72 src/launchers/lutris.vala:67
msgid "Wine build with the Staging patchset and many other useful patches."
msgstr ""
"Wine sestavené se sadou patchů Staging a mnoha dalšími užitečnými patchi."

#: src/launchers/hgl.vala:90 src/launchers/steam.vala:67
msgid "Custom Proton build for running Windows games, based on Wine-tkg."
msgstr ""
"Vlastní sestavení Protonu pro spouštění her pro Windows, založené na Wine-"
"tkg."

#: src/launchers/lutris.vala:87
msgid "Contains RTX fix for Star Citizen."
msgstr "Obsahuje opravu RTX pro Star Citizen."

#: src/launchers/steam.vala:63
msgid ""
"Steam compatibility tool for running Windows games with improvements over "
"Valve's default Proton."
msgstr ""
"Nástroj kompatibility Steam pro spouštění her pro Windows s vylepšeními "
"oproti výchozímu Protonu od Valve."

#: src/launchers/steam.vala:70 src/launchers/steam.vala:73
#, c-format
msgid ""
"Steam compatibility tool based on Proton-GE with modifications for very old "
"GPUs, with %s."
msgstr ""
"Nástroj kompatibility Steam založený na Proton-GE s úpravami pro velmi stará "
"GPU, s %s."

#: src/launchers/steam.vala:77
msgid ""
"Luxtorpeda provides Linux-native game engines for certain Windows-only games."
msgstr ""
"Luxtorpeda poskytuje nativní linuxové herní enginy pro některé hry dostupné "
"pouze pro Windows."

#: src/launchers/steam.vala:78
msgid "Steam compatibility tool for running DOS games using DOSBox for Linux."
msgstr ""
"Nástroj kompatibility Steam pro spouštění her pro DOS pomocí DOSBoxu pro "
"Linux."

#: src/launchers/steam.vala:79
msgid ""
"Steam compatibility tool for running adventure games using ScummVM for Linux."
msgstr ""
"Nástroj kompatibility Steam pro spouštění her z žánru adventur pomocí "
"ScummVM pro Linux."

#: src/launchers/steam.vala:80
msgid "Custom Proton build for running the Northstar client for Titanfall 2."
msgstr ""
"Vlastní sestavení Protonu pro spouštění klienta Northstar pro Titanfall 2."

#: src/launchers/steam.vala:81
msgid ""
"Steam compatibility tool based on Proton-GE with additional patches to "
"improve RTSP codecs for VRChat."
msgstr ""
"Nástroj kompatibility Steam založený na Proton-GE s dalšími patchi pro "
"vylepšení kodeků RTSP pro VRChat."

#: src/launchers/steam.vala:85
msgid ""
"Steam tool for easy, graphical configuration of your other compatibility "
"tools for both Windows games and native Linux games."
msgstr ""
"Nástroj Steamu pro snadnou grafickou konfiguraci vašich dalších nástrojů "
"kompatibility pro Windows hry i nativní hry pro Linux."

#: src/launchers/steam.vala:336
msgid "Missing dependencies!"
msgstr "Chybějící závislosti!"

#: src/launchers/steam.vala:336
#, c-format
msgid "You are missing the following dependencies for %s:"
msgstr "Pro %s vám chybí následující závislosti:"

#: src/launchers/steam.vala:336
msgid "Installation will be canceled."
msgstr "Instalace bude zrušena."

#: src/launchers/steam.vala:337 src/launchers/steam.vala:349
#: src/launchers/steam.vala:648
msgid "OK"
msgstr "Budiž"

#: src/launchers/steam.vala:347
#, c-format
msgid "Existing installation of %s"
msgstr "Existující instalace %s"

#: src/launchers/steam.vala:347
#, c-format
msgid ""
"It looks like you currently have another version of %s which was not "
"installed by ProtonPlus."
msgstr ""
"Zdá se, že aktuálně máte jinou verzi %s, která nebyla nainstalována přes "
"ProtonPlus."

#: src/launchers/steam.vala:347
#, c-format
msgid "Do you want to delete it and install %s with ProtonPlus?"
msgstr "Chcete ji smazat a nainstalovat %s s ProtonPlus?"

#: src/launchers/steam.vala:348
msgid "Cancel"
msgstr "Zrušit"

#: src/launchers/steam.vala:556 src/launchers/steam.vala:568
#, c-format
msgid "Delete %s"
msgstr "Smazat %s"

#: src/launchers/steam.vala:558
#, c-format
msgid "Install %s"
msgstr "Nainstalovat %s"

#: src/launchers/steam.vala:559
msgid "Show more information"
msgstr "Zobrazit více informací"

#: src/launchers/steam.vala:566
msgid "Check this to also delete your configuration files."
msgstr "Zvolte pro smazání také konfiguračních souborů."

#: src/launchers/steam.vala:568
#, c-format
msgid "You're about to delete %s from your system."
msgstr "Chystáte se smazat %s ze svého systému."

#: src/launchers/steam.vala:568
msgid "Are you sure you want this?"
msgstr "Opravdu to chcete udělat?"

#: src/launchers/steam.vala:570
msgid "No"
msgstr "Ne"

#: src/launchers/steam.vala:571
msgid "Yes"
msgstr "Ano"

#: src/launchers/steam.vala:587
#, c-format
msgid "An unexpected error occurred while removing %s."
msgstr "Při odstraňování %s došlo k neočekávané chybě."

#: src/launchers/steam.vala:596
#, c-format
msgid "%s is already up-to-date."
msgstr "%s je již aktuální."

#: src/launchers/steam.vala:598
#, c-format
msgid "The upgrade of %s has begun."
msgstr "Aktualizace %s byla zahájena."

#: src/launchers/steam.vala:608
#, c-format
msgid "The upgrade of %s is complete."
msgstr "Aktualizace %s je dokončena."

#: src/launchers/steam.vala:610
#, c-format
msgid "An unexpected error occurred while upgrading %s."
msgstr "Při aktualizaci %s došlo k neočekávané chybě."

#: src/launchers/steam.vala:641 src/launchers/steam.vala:644
#, c-format
msgid "%s is not supported"
msgstr "%s není podporováno"

#: src/launchers/steam.vala:641
#, c-format
msgid "To install %s for the %s, please run the following command:"
msgstr "Chcete-li nainstalovat %s pro %s, spusťte následující příkaz:"

#: src/launchers/steam.vala:644
#, c-format
msgid "There's currently no known way for us to install %s for the %s."
msgstr "Momentálně není znám žádný způsob, jak nainstalovat %s pro %s."

#: src/launchers/steam.vala:714
#, c-format
msgid "%s is up-to-date"
msgstr "%s je aktuální"

#: src/launchers/steam.vala:714
#, c-format
msgid "Update %s to the latest version"
msgstr "Aktualizujte %s na nejnovější verzi"

#: src/models/release.vala:63
msgid "Not Available"
msgstr "Není dostupné"

