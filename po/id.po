msgstr "Tambahkan opsi peluncuran Anda sendiri."

msgid "Advanced options"
msgstr "Opsi lanjutan"

msgid "Extra control over the final Steam launch command."
msgstr "Kontrol ekstra atas perintah peluncuran Steam akhir."

msgid "Fullscreen"
msgstr "Layar penuh"

msgid "Runs the game in a fullscreen session."
msgstr "Menjalankan game dalam sesi layar penuh."

msgid "VRR"
msgstr "VRR"

msgid "Matches your display's refresh rate to the game's FPS."
msgstr "Mencocokkan refresh rate layar Anda dengan FPS game."

msgid "Frame limit"
msgstr "Batas frame"

msgid "Caps the frame rate inside Gamescope."
msgstr "Membatasi frame rate di dalam Gamescope."

msgid "FPS"
msgstr "FPS"

msgid "Resolution"
msgstr "Resolusi"

msgid "Sets the Gamescope output resolution."
msgstr "Mengatur resolusi output Gamescope."

msgid "Additional Gamescope arguments"
msgstr "Argumen Gamescope tambahan"

msgid "Keeps extra Gamescope flags such as output or resolution tweaks."
msgstr ""
"Menyimpan flag Gamescope ekstra seperti penyesuaian output atau resolusi."

msgid "Add Gamescope arguments"
msgstr "Tambahkan argumen Gamescope"

msgid "Auto HDR"
msgstr "Auto HDR"

msgid "Caps the frame rate inside ScopeBuddy."
msgstr "Membatasi frame rate di dalam ScopeBuddy."

msgid "Sets the ScopeBuddy output resolution."
msgstr "Mengatur resolusi output ScopeBuddy."

msgid "Additional ScopeBuddy arguments"
msgstr "Argumen ScopeBuddy tambahan"

msgid "Keeps extra ScopeBuddy flags such as preferred output selection."
msgstr ""
"Menyimpan flag ScopeBuddy ekstra seperti pemilihan output yang diinginkan."

msgid "Add ScopeBuddy arguments"
msgstr "Tambahkan argumen ScopeBuddy"

