<?xml version="1.0" encoding="UTF-8"?>
<schemalist gettext-domain="com.vysp3r.ProtonPlus">
    <enum id="com.vysp3r.ProtonPlus.Theme">
        <value nick="system" value="0"/>
        <value nick="dark" value="4"/>
        <value nick="light" value="1"/>
        <value nick="steamos" value="5"/>
        <value nick="oled" value="6"/>
    </enum>

    <enum id="com.vysp3r.ProtonPlus.UpdateFrequency">
        <value nick="1h" value="0"/>
        <value nick="3h" value="1"/>
        <value nick="6h" value="2"/>
        <value nick="12h" value="3"/>
    </enum>

	<enum id="com.vysp3r.ProtonPlus.ProxyMode">
		<value nick="system" value="0"/>
		<value nick="manual" value="1"/>
  </enum>
    
	<enum id="com.vysp3r.ProtonPlus.Language">
		<value nick="system" value="0"/>
        <value nick="ar" value="1"/>
        <value nick="be" value="2"/>
        <value nick="bs" value="3"/>
        <value nick="cs" value="4"/>
        <value nick="de" value="5"/>
        <value nick="en" value="6"/>
        <value nick="el" value="7"/>
        <value nick="es" value="8"/>
        <value nick="fi" value="9"/>
        <value nick="fr" value="10"/>
        <value nick="hr" value="11"/>
        <value nick="id" value="12"/>
        <value nick="it" value="13"/>
        <value nick="ja" value="14"/>
        <value nick="ka" value="15"/>
        <value nick="nl" value="16"/>
        <value nick="pl" value="17"/>
        <value nick="pt" value="18"/>
        <value nick="ru" value="19"/>
        <value nick="sr@latin" value="20"/>
        <value nick="sv" value="21"/>
        <value nick="uk" value="22"/>
        <value nick="vi" value="23"/>
        <value nick="zh-CN" value="24"/>
        <value nick="zh-TW" value="25"/>
        <value nick="sk" value="26"/>
	</enum>

    <schema id="com.vysp3r.ProtonPlus.State" path="/com/vysp3r/ProtonPlus/State/">
        <key name="width" type="i">
            <default>950</default>
        </key>
        <key name="height" type="i">
            <default>600</default>
        </key>
        <key name="is-maximized" type="b">
            <default>false</default>
        </key>
        <key name="is-fullscreen" type="b">
            <default>false</default>
        </key>
        <key name="automatic-updates" type="b">
            <default>true</default>
        </key>
        <key name="update-frequency" enum="com.vysp3r.ProtonPlus.UpdateFrequency">
            <default>'1h'</default>
        </key>
        <key name="check-updates-on-boot" type="b">
            <default>true</default>
        </key>
        <key name="github-api-key" type="s">
            <default>''</default>
        </key>
        <key name="gitlab-api-key" type="s">
            <default>''</default>
        </key>
        <key name="steam-last-profile-id" type="s">
            <default>''</default>
        </key>
        <key name="steam-remember-last-profile" type="b">
            <default>true</default>
        </key>
        <key name="enable-controller" type="b">
            <default>true</default>
        </key>
        <key name="first-run" type="b">
            <default>true</default>
        </key>
        <key name="theme" enum="com.vysp3r.ProtonPlus.Theme">
            <default>'system'</default>
        </key>
		<key name="language" enum="com.vysp3r.ProtonPlus.Language">
			<default>'system'</default>
		</key>
        <key name="experimental-features" type="b">
            <default>false</default>
        </key>
        <key name="show-legacy-tools" type="b">
            <default>false</default>
        </key>
		<key name="proxy-mode" enum="com.vysp3r.ProtonPlus.ProxyMode">
			<default>'system'</default>
		</key>
		<key name="proxy-url" type="s">
			<default>''</default>
		</key>
    </schema>
</schemalist>